# Supabase JWT Secret — required for /cbc/analyze auth.
# Get it from: Supabase Dashboard → Project Settings → API → JWT Secret
# (This is NOT the anon/public key.)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Never commit live JWT access tokens, service_role keys, or DATABASE_URL passwords to git.

# Postgres (Supabase). For RLS policies on runtime tables, the API sets
# request.jwt.claim.sub per request from the validated JWT — use the normal
# database password connection string (Session mode / port 5432 recommended).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional: total wait timeout (seconds) for polling S18 GET /runs/{id}. Exposed in GET /health; use >=900 for full WISE runs that often exceed 5 minutes.
# RUN_POLL_TIMEOUT_SECONDS=900
