# Supabase JWT Secret — required for /cbc/analyze auth.
# Get it from: Supabase Dashboard → Project Settings → API → JWT Secret
# (This is NOT the anon/public key.)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Optional: database URL if using DB
# DATABASE_URL=postgresql://...

# Optional: total wait timeout (seconds) for polling S18 GET /runs/{id}. Exposed in GET /health; clients/gateways should use at least this (e.g. 300) so long runs aren't cut off.
# RUN_POLL_TIMEOUT_SECONDS=300
