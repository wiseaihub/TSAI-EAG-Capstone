# --- replace the placeholders with your actual environment values; save this as .env file in repo root and /deployment/docker folders ---
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Note: DATABASE_URL is the "Transaction" connection string from Supabase > Settings > Database
DATABASE_URL=postgresql://postgres.<your-project>:<your-DB-password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<your-project>.supabase.co

S18_BASE_URL=http://localhost:8000
RUN_POLL_TIMEOUT_SECONDS=920